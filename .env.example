# Copy this file to .env and fill in your values.
# cp .env.example .env

# MySQL / WordPress database credentials
# IMPORTANT: Replace ALL passwords below with strong, unique values before deployment.
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=change_me_db_password

# WordPress table prefix (optional, default: wp_)
WORDPRESS_TABLE_PREFIX=wp_

# Host ports for the services
WORDPRESS_PORT=8080
PHPMYADMIN_PORT=8081
